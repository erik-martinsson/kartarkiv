---
const { race } = Astro.props;
const base = import.meta.env.BASE_URL;
const d = race.data;
---
<article class="race-card">
  <a href={`${base}races/${race.id}/`} class="race-image-wrap">
    <img src={`${base}${d.mapImage.replace(/^\//, '')}`} alt={`Karta från ${d.title}`} class="race-image" loading="lazy" />
    <span class="date-pill">{d.date.toLocaleDateString('sv-SE')}</span>
  </a>
  <div class="race-body">
    <h3><a href={`${base}races/${race.id}/`}>{d.title}</a></h3>
    <p class="muted">{d.location} · {d.class}</p>
    <div class="race-meta"><span>{d.distanceKm.toFixed(1)} km</span><span>{d.time}</span><span>{d.position}:a</span></div>
    <div class="race-actions">
      <a href={`${base}races/${race.id}/`} aria-label="Öppna lopp">🗺</a>
      {d.winsplits && <a href={d.winsplits} target="_blank" rel="noreferrer" aria-label="Winsplits">↗</a>}
      {d.livelox && <a href={d.livelox} target="_blank" rel="noreferrer" aria-label="Livelox">◎</a>}
    </div>
  </div>
</article>
