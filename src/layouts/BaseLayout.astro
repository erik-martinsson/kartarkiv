---
import '../styles/global.css';
const { title = 'Erik Orientering – Kartarkiv', description = 'Ett publikt arkiv med orienteringskartor, resultat och analyser.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>
        <span class="brand-mark">⌁</span>
        <span><strong>ERIK ORIENTERING</strong><small>KARTARKIV</small></span>
      </a>
      <nav>
        <a href={base}>Hem</a>
        <a href={`${base}races/`}>Kartor</a>
        <a href={`${base}#statistik`}>Statistik</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>© {new Date().getFullYear()} Erik Martinsson · Byggd med Astro och GitHub Pages</footer>
  </body>
</html>
