---
import '../styles/global.css';

const {
  title = 'Erik Martinssons Kartarkiv',
  description = 'Ett publikt arkiv med orienteringskartor, resultat och analyser.'
} = Astro.props;

const base = import.meta.env.BASE_URL;
const cleanBase = base.replace(/\/$/, '');
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <header class="site-header">
      <a
        class="brand"
        href={`${cleanBase}/`}
        aria-label="Gå till startsidan"
      >
        <span class="brand-mark">⌁</span>

        <span>
          <strong>ERIK MARTINSSON</strong>
          <small>KARTARKIV</small>
        </span>
      </a>

      <nav aria-label="Huvudmeny">
        <a href={`${cleanBase}/`}>
          Hem
        </a>

        <a href={`${cleanBase}/races/`}>
          Kartarkiv
        </a>

        <a href={`${cleanBase}/statistics/`}>
          Statistik
        </a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      © {new Date().getFullYear()} Erik Martinsson · Byggd med Astro och GitHub Pages
    </footer>
  </body>
</html>