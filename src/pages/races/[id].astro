---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const races = await getCollection('races');
  return races.map(race => ({ params: { id: race.id }, props: { race } }));
}
const { race } = Astro.props;
const { Content } = await render(race);
const d = race.data;
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={`${d.title} – Kartarkiv`}>
  <section class="page-shell detail-page">
    <a class="back-link" href={`${base}races/`}>← Alla kartor</a>
    <div class="detail-header"><div><p class="eyebrow">{d.date.toLocaleDateString('sv-SE')}</p><h1>{d.title}</h1><p>{d.location} · {d.class}</p></div><div class="detail-stats"><span><strong>{d.time}</strong>Tid</span><span><strong>{d.position}:a</strong>Placering</span><span><strong>{d.distanceKm.toFixed(1)} km</strong>Distans</span></div></div>
    <img class="detail-map" src={`${base}${d.mapImage.replace(/^\//,'')}`} alt={`Orienteringskarta från ${d.title}`} />
    <div class="detail-grid">
      <article class="panel prose"><h2>Analys</h2><Content /></article>
      <aside class="panel link-panel"><h2>Länkar</h2>{d.mapPdf && <a href={`${base}${d.mapPdf.replace(/^\//,'')}`} target="_blank">Öppna PDF-karta</a>}{d.livelox && <a href={d.livelox} target="_blank">Öppna Livelox</a>}{d.winsplits && <a href={d.winsplits} target="_blank">Öppna Winsplits</a>}{d.results && <a href={d.results} target="_blank">Öppna resultat</a>}</aside>
    </div>
  </section>
</BaseLayout>
