---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const races = await getCollection('races');

  return races.map((race) => ({
    params: { id: race.id },
    props: { race }
  }));
}

const { race } = Astro.props;
const { Content } = await render(race);

const base = import.meta.env.BASE_URL;
const cleanBase = base.replace(/\/$/, '');

const mapImageUrl = race.data.mapImage
  ? `${cleanBase}/${race.data.mapImage.replace(/^\/+/, '')}`
  : '';

const routeImageUrl = race.data.routeImage
  ? `${cleanBase}/${race.data.routeImage.replace(/^\/+/, '')}`
  : '';

const initialMapImageUrl = routeImageUrl || mapImageUrl;

const courseDistance =
  typeof race.data.distanceKm === 'number' ? race.data.distanceKm : 0;

const gpsDistance =
  typeof race.data.gpsDistanceKm === 'number' ? race.data.gpsDistanceKm : 0;

const courseDistanceText =
  courseDistance > 0 ? `${courseDistance.toFixed(2)} km` : '–';

const gpsDistanceText =
  gpsDistance > 0 ? `${gpsDistance.toFixed(2)} km` : '–';

const extraDistancePercent =
  courseDistance > 0 && gpsDistance > 0
    ? ((gpsDistance - courseDistance) / courseDistance) * 100
    : null;

const extraDistancePercentText =
  extraDistancePercent !== null
    ? `${extraDistancePercent.toFixed(1)} %`
    : '–';

const positionText =
  typeof race.data.position === 'number' ? `${race.data.position}:a` : '–';

const placementText =
  typeof race.data.position === 'number' &&
  typeof race.data.starters === 'number'
    ? `${race.data.position}:a av ${race.data.starters}`
    : positionText;

const mistakeSeconds =
  typeof race.data.mistakeSeconds === 'number'
    ? race.data.mistakeSeconds
    : 0;

const mistakeTimeText = `${Math.floor(mistakeSeconds / 60)}:${String(
  mistakeSeconds % 60
).padStart(2, '0')}`;

const timeToSeconds = (time) => {
  if (!time) return 0;

  const parts = String(time).split(':').map(Number);
  if (parts.some(Number.isNaN)) return 0;

  return parts.reduce((total, part) => total * 60 + part, 0);
};

const raceTimeSeconds = timeToSeconds(race.data.time);
const mistakePercent =
  raceTimeSeconds > 0 ? (mistakeSeconds / raceTimeSeconds) * 100 : 0;
const mistakePercentText = `${mistakePercent.toFixed(1)} %`;

const paceSecondsPerKm =
  raceTimeSeconds > 0 && gpsDistance > 0
    ? Math.round(raceTimeSeconds / gpsDistance)
    : null;

const paceText =
  paceSecondsPerKm !== null
    ? `${Math.floor(paceSecondsPerKm / 60)}:${String(
        paceSecondsPerKm % 60
      ).padStart(2, '0')}`
    : '–';

const climbText =
  typeof race.data.gpsClimb === 'number'
    ? `${Math.round(race.data.gpsClimb)} m`
    : '–';


---

<BaseLayout>
  <main class="detail-page page-shell">
    <a href={`${cleanBase}/races/`} class="back-link">← Alla kartor</a>

    <header class="detail-header">
      <p class="eyebrow">{race.data.date.toLocaleDateString('sv-SE')}</p>
      <h1>{race.data.title}</h1>

      <div class="detail-subtitle">
        <span>{race.data.location}</span>
        <span>{race.data.raceClass}</span>
        <span>{race.data.discipline}</span>
        <span>{race.data.club}</span>
      </div>
    </header>

    <div class="race-detail-main">
      <section class="race-map-panel">
        {
          routeImageUrl && (
            <div class="race-map-controls">
              <button
                type="button"
                class="map-variant-toggle is-active"
                id="map-variant-toggle"
                aria-pressed="true"
              >
                Visa blank karta
              </button>
            </div>
          )
        }

        {
          initialMapImageUrl && (
            <button
              type="button"
              class="race-map-button"
              id="open-map-lightbox"
              aria-label={`Öppna kartan från ${race.data.title} i stort format`}
            >
              <img
                src={initialMapImageUrl}
                data-blank-src={mapImageUrl}
                data-route-src={routeImageUrl}
                alt={`Orienteringskarta från ${race.data.title}`}
                class="detail-map"
                id="detail-map-image"
              />
              <span class="map-enlarge-hint">Klicka för att förstora</span>
            </button>
          )
        }
      </section>

      <aside class="panel race-detail-stats">
        <h2>STATISTIK</h2>

<div class="detail-stat-grid">
  <div>
    <span>Tävlingstid</span>
    <strong>{race.data.time}</strong>
  </div>

  <div>
    <span>Placering</span>
    <strong>{placementText}</strong>
  </div>

  <div>
    <span>Banlängd</span>
    <strong>{courseDistanceText}</strong>
  </div>

  <div>
    <span>Löpt distans</span>
    <strong>{gpsDistanceText}</strong>
  </div>

  <div>
    <span>Extra löpt distans</span>
    <strong>{extraDistancePercentText}</strong>
  </div>

  <div>
    <span>Tempo (min/km)</span>
    <strong>{paceText}</strong>
  </div>

  <div>
    <span>Bomtid</span>
    <strong>{mistakeTimeText}</strong>
  </div>

  <div>
    <span>Bomtid (%)</span>
    <strong>{mistakePercentText}</strong>
  </div>

  <div>
    <span>Kontroller</span>
    <strong>{race.data.controls ?? '–'}</strong>
  </div>

  <div>
    <span>Höjdmeter</span>
    <strong>{climbText}</strong>
  </div>
</div>
      </aside>
    </div>

    <div class="detail-grid">
      <section class="panel prose">
        <h2>ANALYS</h2>
        <Content />
      </section>

      <aside class="panel link-panel">
        <h2>LÄNKAR</h2>
        {race.data.livelox && <a href={race.data.livelox} target="_blank" rel="noreferrer">Öppna Livelox</a>}
        {race.data.winsplits && <a href={race.data.winsplits} target="_blank" rel="noreferrer">Öppna Winsplits</a>}
        {race.data.results && <a href={race.data.results} target="_blank" rel="noreferrer">Öppna resultat</a>}
      </aside>
    </div>
  </main>

  {
    initialMapImageUrl && (
      <dialog class="map-lightbox" id="map-lightbox" aria-label={`Förstorad karta från ${race.data.title}`}>
        <div class="map-lightbox-toolbar">
          <div class="map-lightbox-title">
            <strong>{race.data.title}</strong>
            <span>{race.data.date.toLocaleDateString('sv-SE')}</span>
          </div>

          <div class="map-lightbox-actions">
  {
    routeImageUrl && (
      <button
        type="button"
        id="map-lightbox-variant-toggle"
        class="map-lightbox-variant-toggle is-active"
        aria-pressed="true"
      >
        Visa blank karta
      </button>
    )
  }

  <button
    type="button"
    id="map-zoom-out"
    aria-label="Zooma ut"
  >
    −
  </button>

  <button
    type="button"
    id="map-zoom-reset"
    aria-label="Återställ zoom"
  >
    100 %
  </button>

  <button
    type="button"
    id="map-zoom-in"
    aria-label="Zooma in"
  >
    +
  </button>

  <button
    type="button"
    id="close-map-lightbox"
    class="map-lightbox-close"
    aria-label="Stäng kartan"
  >
    ×
  </button>
</div>
        </div>

        <div class="map-lightbox-stage" id="map-lightbox-stage">
          <img
            src={initialMapImageUrl}
            data-blank-src={mapImageUrl}
            data-route-src={routeImageUrl}
            alt={`Förstorad orienteringskarta från ${race.data.title}`}
            class="map-lightbox-image"
            id="map-lightbox-image"
            draggable="false"
          />
        </div>

        <p class="map-lightbox-help">Zooma med mushjulet och dra kartan när den är inzoomad. Dubbelklick återställer zoom.</p>
      </dialog>
    )
  }

  <script>
    const openButton = document.querySelector('#open-map-lightbox');
    const dialog = document.querySelector('#map-lightbox');
    const closeButton = document.querySelector('#close-map-lightbox');
    const zoomInButton = document.querySelector('#map-zoom-in');
    const zoomOutButton = document.querySelector('#map-zoom-out');
    const resetButton = document.querySelector('#map-zoom-reset');
    const stage = document.querySelector('#map-lightbox-stage');
    const lightboxImage = document.querySelector('#map-lightbox-image');
    const detailMapImage = document.querySelector('#detail-map-image');
    const mapVariantToggle = document.querySelector('#map-variant-toggle');
    const lightboxVariantToggle = document.querySelector(
      '#map-lightbox-variant-toggle'
    );

    if (
      openButton instanceof HTMLButtonElement &&
      dialog instanceof HTMLDialogElement &&
      closeButton instanceof HTMLButtonElement &&
      zoomInButton instanceof HTMLButtonElement &&
      zoomOutButton instanceof HTMLButtonElement &&
      resetButton instanceof HTMLButtonElement &&
      stage instanceof HTMLElement &&
      lightboxImage instanceof HTMLImageElement
    ) {
      let scale = 1;
      let translateX = 0;
      let translateY = 0;

      let isDragging = false;
      let dragPointerId = null;
      let dragStartX = 0;
      let dragStartY = 0;
      let startTranslateX = 0;
      let startTranslateY = 0;

      const activePointers = new Map();

      let pinchStartDistance = 0;
      let pinchStartScale = 1;
      let pinchStartTranslateX = 0;
      let pinchStartTranslateY = 0;
      let pinchStartCenterX = 0;
      let pinchStartCenterY = 0;

      const minimumScale = 1;
      const maximumScale = 5;
      const zoomStep = 0.25;

      const clampScale = (value) =>
        Math.min(maximumScale, Math.max(minimumScale, value));

      const applyTransform = () => {
        lightboxImage.style.transform =
          `translate(${translateX}px, ${translateY}px) scale(${scale})`;

        resetButton.textContent = `${Math.round(scale * 100)} %`;
        stage.classList.toggle('is-zoomed', scale > minimumScale);
      };

      const resetView = () => {
        scale = 1;
        translateX = 0;
        translateY = 0;

        isDragging = false;
        dragPointerId = null;
        activePointers.clear();
        pinchStartDistance = 0;

        stage.classList.remove('is-dragging');
        applyTransform();
      };

      const changeZoom = (change) => {
        scale = clampScale(scale + change);

        if (scale === minimumScale) {
          translateX = 0;
          translateY = 0;
        }

        applyTransform();
      };

      const getPointerValues = () =>
        Array.from(activePointers.values());

      const getDistance = (first, second) =>
        Math.hypot(
          second.x - first.x,
          second.y - first.y
        );

      const getCenter = (first, second) => ({
        x: (first.x + second.x) / 2,
        y: (first.y + second.y) / 2
      });

      const beginPinch = () => {
        const pointers = getPointerValues();

        if (pointers.length < 2) return;

        const first = pointers[0];
        const second = pointers[1];
        const center = getCenter(first, second);

        pinchStartDistance = getDistance(first, second);
        pinchStartScale = scale;
        pinchStartTranslateX = translateX;
        pinchStartTranslateY = translateY;
        pinchStartCenterX = center.x;
        pinchStartCenterY = center.y;

        isDragging = false;
        dragPointerId = null;
        stage.classList.add('is-dragging');
      };

      const updatePinch = () => {
        const pointers = getPointerValues();

        if (
          pointers.length < 2 ||
          pinchStartDistance <= 0
        ) {
          return;
        }

        const first = pointers[0];
        const second = pointers[1];

        const currentDistance = getDistance(first, second);
        const currentCenter = getCenter(first, second);

        scale = clampScale(
          pinchStartScale *
          (currentDistance / pinchStartDistance)
        );

        translateX =
          pinchStartTranslateX +
          currentCenter.x -
          pinchStartCenterX;

        translateY =
          pinchStartTranslateY +
          currentCenter.y -
          pinchStartCenterY;

        if (scale === minimumScale) {
          translateX = 0;
          translateY = 0;
        }

        applyTransform();
      };

      const openLightbox = () => {
        resetView();
        dialog.showModal();
        document.body.classList.add('lightbox-open');
      };

      const closeLightbox = () => {
        dialog.close();
        document.body.classList.remove('lightbox-open');
        resetView();
      };

      openButton.addEventListener('click', openLightbox);
      closeButton.addEventListener('click', closeLightbox);

      zoomInButton.addEventListener('click', () => {
        changeZoom(zoomStep);
      });

      zoomOutButton.addEventListener('click', () => {
        changeZoom(-zoomStep);
      });

      resetButton.addEventListener('click', resetView);

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          closeLightbox();
        }
      });

      dialog.addEventListener('cancel', (event) => {
        event.preventDefault();
        closeLightbox();
      });

      dialog.addEventListener('close', () => {
        document.body.classList.remove('lightbox-open');
        resetView();
      });

      stage.addEventListener(
        'wheel',
        (event) => {
          event.preventDefault();
          changeZoom(event.deltaY < 0 ? zoomStep : -zoomStep);
        },
        { passive: false }
      );

      stage.addEventListener('dblclick', resetView);

      stage.addEventListener('pointerdown', (event) => {
        event.preventDefault();

        activePointers.set(event.pointerId, {
          x: event.clientX,
          y: event.clientY
        });

        stage.setPointerCapture(event.pointerId);

        if (activePointers.size === 2) {
          beginPinch();
          return;
        }

        if (
          activePointers.size === 1 &&
          scale > minimumScale
        ) {
          isDragging = true;
          dragPointerId = event.pointerId;

          dragStartX = event.clientX;
          dragStartY = event.clientY;
          startTranslateX = translateX;
          startTranslateY = translateY;

          stage.classList.add('is-dragging');
        }
      });

      stage.addEventListener('pointermove', (event) => {
        if (!activePointers.has(event.pointerId)) {
          return;
        }

        event.preventDefault();

        activePointers.set(event.pointerId, {
          x: event.clientX,
          y: event.clientY
        });

        if (activePointers.size >= 2) {
          updatePinch();
          return;
        }

        if (
          isDragging &&
          dragPointerId === event.pointerId
        ) {
          translateX =
            startTranslateX +
            event.clientX -
            dragStartX;

          translateY =
            startTranslateY +
            event.clientY -
            dragStartY;

          applyTransform();
        }
      });

      const stopPointer = (event) => {
        activePointers.delete(event.pointerId);

        if (stage.hasPointerCapture(event.pointerId)) {
          stage.releasePointerCapture(event.pointerId);
        }

        if (
          activePointers.size === 1 &&
          scale > minimumScale
        ) {
          const iterator = activePointers.entries().next();

          if (!iterator.done) {
            const [remainingPointerId, point] = iterator.value;

            isDragging = true;
            dragPointerId = remainingPointerId;
            dragStartX = point.x;
            dragStartY = point.y;
            startTranslateX = translateX;
            startTranslateY = translateY;

            stage.classList.add('is-dragging');
          }
        } else {
          isDragging = false;
          dragPointerId = null;

          if (activePointers.size === 0) {
            stage.classList.remove('is-dragging');
          }
        }

        pinchStartDistance = 0;
      };

      stage.addEventListener('pointerup', stopPointer);
      stage.addEventListener('pointercancel', stopPointer);
    }

    if (
      mapVariantToggle instanceof HTMLButtonElement &&
      detailMapImage instanceof HTMLImageElement &&
      lightboxImage instanceof HTMLImageElement
    ) {
      let showingRoute =
        Boolean(detailMapImage.dataset.routeSrc);

      const updateToggleButton = (button) => {
        if (!(button instanceof HTMLButtonElement)) {
          return;
        }

        button.textContent = showingRoute
          ? 'Visa blank karta'
          : 'Visa GPS-rutt';

        button.setAttribute(
          'aria-pressed',
          showingRoute ? 'true' : 'false'
        );

        button.classList.toggle(
          'is-active',
          showingRoute
        );
      };

      const updateMapVariant = () => {
        const blankSrc =
          detailMapImage.dataset.blankSrc ?? '';

        const routeSrc =
          detailMapImage.dataset.routeSrc ?? '';

        const nextSrc =
          showingRoute && routeSrc
            ? routeSrc
            : blankSrc;

        detailMapImage.src = nextSrc;
        lightboxImage.src = nextSrc;

        updateToggleButton(mapVariantToggle);
        updateToggleButton(lightboxVariantToggle);
      };

      const toggleMapVariant = () => {
        showingRoute = !showingRoute;
        updateMapVariant();
      };

      mapVariantToggle.addEventListener(
        'click',
        toggleMapVariant
      );

      if (
        lightboxVariantToggle instanceof HTMLButtonElement
      ) {
        lightboxVariantToggle.addEventListener(
          'click',
          toggleMapVariant
        );
      }

      updateMapVariant();
    }
  </script>
</BaseLayout>
