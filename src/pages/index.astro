---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import RaceCard from '../components/RaceCard.astro';

const races = (await getCollection('races')).sort((a,b) => b.data.date.getTime() - a.data.date.getTime());
const recent = races.slice(0,5);
const totalMistakes = races.reduce((sum,r) => sum + r.data.mistakeSeconds, 0);
const avgMistake = races.length ? Math.round(totalMistakes/races.length) : 0;
const bestPosition = races.length ? Math.min(...races.map(r=>r.data.position)) : 0;
const controls = races.reduce((sum,r)=>sum+(r.data.controls ?? 0),0);
const years = [...new Set(races.map(r=>r.data.date.getFullYear()))];
const fmt = (s) => `${Math.floor(s/3600)}:${String(Math.floor((s%3600)/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`;
---
<BaseLayout>
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">VÄLKOMMEN TILL MITT</p>
      <h1>KARTARKIV</h1>
      <p>Här samlar jag orienteringskartor, resultat och analyser.<br/>Varje lopp är ett minne, varje karta en historia.</p>
      <div class="hero-stats">
        <div><strong>{races.length}</strong><span>KARTOR</span></div>
        <div><strong>{races.length}</strong><span>TÄVLINGAR</span></div>
        <div><strong>{years.length}</strong><span>ÅR</span></div>
        <div><strong>{controls}</strong><span>KONTROLLER</span></div>
      </div>
    </div>
  </section>

  <section class="dashboard-grid page-shell">
    <div class="panel latest-panel">
      <div class="panel-heading"><h2>SENASTE KARTORNA</h2><a href={`${import.meta.env.BASE_URL}races/`}>Visa alla ›</a></div>
      <div class="race-grid">{recent.map(race => <RaceCard race={race} />)}</div>
    </div>

    <aside class="panel stats-panel" id="statistik">
      <h2>STATISTIK ÖVERSIKT</h2>
      <div class="stat-grid">
        <div><span>Total bomtid</span><strong>{fmt(totalMistakes)}</strong></div>
        <div><span>Gen. bomtid/lopp</span><strong>{Math.floor(avgMistake/60)}:{String(avgMistake%60).padStart(2,'0')}</strong></div>
        <div><span>Bästa placering</span><strong>{bestPosition ? `${bestPosition}:a` : '–'}</strong></div>
        <div><span>Antal lopp</span><strong>{races.length}</strong></div>
        <div><span>Bomfria lopp</span><strong>{races.filter(r=>r.data.mistakeSeconds===0).length}</strong></div>
        <div><span>Kontroller</span><strong>{controls}</strong></div>
      </div>
    </aside>

    <div class="panel chart-panel">
      <h2>BOMTID PER LOPP</h2>
      <div class="bars">
        {races.slice().reverse().map(r => <div class="bar-item" title={`${r.data.title}: ${Math.round(r.data.mistakeSeconds/60)} min`}><div class="bar" style={`height:${Math.max(8, Math.min(100, r.data.mistakeSeconds/6))}%`}></div><span>{r.data.date.getFullYear()}</span></div>)}
      </div>
    </div>

    <div class="panel map-panel">
      <h2>TÄVLINGSPLATSER</h2>
      <div class="map-placeholder"><span>●</span><span>●</span><span>●</span><span>●</span><p>Interaktiv karta läggs till i nästa version</p></div>
    </div>
  </section>
</BaseLayout>
